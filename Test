local ValidKeys = {
    "MichaelKey123",
    "VIPKey456",
    "Premium999",
    "BanhMiNuocTuong"
}

local function isValidKey(key)
    for _, v in ipairs(ValidKeys) do
        if v == key then
            return true
        end
    end
    return false
end

if not getgenv().key or not isValidKey(getgenv().key) then return end

